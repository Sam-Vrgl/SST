GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001

# Logging — set LOG_ENABLED=false to suppress all output
LOG_ENABLED=true
# LOG_FILE=enrichment.log

# Set to true to skip keyword tagging (faster runs when only email/institution is needed)
# SKIP_KEYWORDS=true

# Set to true to fall back to first.last@institution-domain for records with no email found
# Emails produced this way are marked with method 'wild-guess'
# WILD_GUESS=true
